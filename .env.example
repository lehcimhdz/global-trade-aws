# ──────────────────────────────────────────────
#  Airflow core
# ──────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3-python3.11
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ──────────────────────────────────────────────
#  Postgres (Airflow metadata database)
# ──────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ──────────────────────────────────────────────
#  AWS credentials
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ──────────────────────────────────────────────
#  Secrets backend
#  Local dev  → LocalFilesystemBackend (reads config/airflow_variables.json)
#  After tf-apply → SecretsManagerBackend (reads from AWS Secrets Manager)
# ──────────────────────────────────────────────
# Uncomment and switch to SecretsManagerBackend after running `make tf-apply`:
# AIRFLOW_SECRETS_BACKEND=airflow.providers.amazon.aws.secrets.secrets_manager.SecretsManagerBackend
# AIRFLOW_SECRETS_BACKEND_KWARGS={"connections_prefix": "airflow/connections", "variables_prefix": "airflow/variables"}
AIRFLOW_SECRETS_BACKEND=airflow.secrets.local_filesystem.LocalFilesystemBackend
AIRFLOW_SECRETS_BACKEND_KWARGS={"variables_file_path": "/opt/airflow/airflow_variables.json"}

# ──────────────────────────────────────────────
#  Comtrade pipeline config
# ──────────────────────────────────────────────
# S3 bucket that serves as the data lake
COMTRADE_S3_BUCKET=your-data-lake-bucket-name

# Default API parameters (can be overridden per-DAG via Airflow Variables)
COMTRADE_TYPE_CODE=C
COMTRADE_FREQ_CODE=A
COMTRADE_CL_CODE=HS
COMTRADE_REPORTER_CODE=
COMTRADE_PERIOD=
COMTRADE_PARTNER_CODE=
COMTRADE_CMD_CODE=
COMTRADE_FLOW_CODE=

# Set to "true" to also write Parquet alongside raw JSON
COMTRADE_WRITE_PARQUET=false
