[flake8]
max-line-length = 100
extend-ignore =
    # E203: whitespace before ':' — conflicts with black
    E203,
    # W503: line break before binary operator — conflicts with black
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    tests/.airflow_home,
    tests/.airflow_test.db
per-file-ignores =
    # Airflow DAG files use module-level Variable.get (not at top of file)
    dags/*.py: E402, F401
    # assert is expected in tests
    tests/*.py: S101
    tests/**/*.py: S101
